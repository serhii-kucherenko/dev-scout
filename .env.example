# Recipient for the daily findings email.
# Add these as GitHub Actions secrets (or local .env).
DEV_SCOUT_EMAIL=

# Resend delivery (required to actually send the findings report)
RESEND_API_KEY=
DELIVERY_FROM=

# Optional alias for recipient
# DELIVERY_TO=

# Optional: override the repo link shown in every brief
# (defaults to repo_url in config/delivery.yaml)
# DEV_SCOUT_REPO_URL=
